<MudDrawerHeader>
    <MudText Typo="Typo.h5" Class="ml-3">STARLIGHT</MudText>
</MudDrawerHeader>
<MudNavMenu Dense="true" Margin="Margin.Normal" Rounded="true" Color="Color.Primary" Class="pa-2">
    <MudNavLink Icon="@Icons.Material.Filled.Home" Href="/" Match="NavLinkMatch.All">
        @_localization["main-layout-home-tab"]
    </MudNavLink>
    <MudNavLink Icon="@Icons.Material.Filled.Computer" Href="/servers" Match="NavLinkMatch.All">
        @_localization["main-layout-servers-tab"]
    </MudNavLink>
    <MudNavLink Icon="@Icons.Material.Filled.Link" Href="/hub" Match="NavLinkMatch.All">
        @_localization["main-layout-hub-tab"]
    </MudNavLink>
    <MudNavLink Icon="@Icons.Material.Filled.Settings" Href="/settings" Match="NavLinkMatch.All">
        @_localization["main-layout-settings-tab"]
    </MudNavLink>
</MudNavMenu>
<MudSpacer />
<MudNavLink Icon="@Icons.Material.Filled.People" Href="/auth" Match="NavLinkMatch.All">
    @_localization["main-layout-auth-tab"]
</MudNavLink>
