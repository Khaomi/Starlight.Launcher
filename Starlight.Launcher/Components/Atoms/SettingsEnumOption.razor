<MudPaper Class="pa-4" Outlined="true" Elevation="0">
    <div class="d-flex align-center">
        <MudIcon Icon="@Icon" Class="mr-4" />
        <div class="flex-grow-1">
            <MudText Typo="Typo.body1">@Title</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                @Description
            </MudText>
        </div>
        <MudSelect Variant="Variant.Outlined" T="int?" Value="@SelectedValue" ValueChanged="OnValueChanged">
            @foreach (var index in Enum.GetValues(Values.GetType()))
            {
                var name = Enum.GetName(Values.GetType(), index);
                <MudSelectItem Value="@index">@name</MudSelectItem>
            }
        </MudSelect>
    </div>
</MudPaper>