@using Starlight.Launcher.Models.ServerStatus

<MudPaper Elevation="0" Square="true" Class="server-toolbar">

    <MudStack Row="true"
              AlignItems="AlignItems.Center"
              Justify="Justify.SpaceBetween"
              Wrap="Wrap.Wrap"
              Spacing="2">

        <MudStack Row="true"
                  AlignItems="AlignItems.Center"
                  Spacing="2"
                  Wrap="Wrap.Wrap">

            <MudTextField T="string"
                          Value="Filters.SearchQuery"
                          ValueChanged="OnSearchChanged"
                          Placeholder="Search servers..."
                          Variant="Variant.Text"
                          Margin="Margin.Dense"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Clearable="true"
                          Immediate="true"
                          Class="server-toolbar__search" />

            <MudSelect T="ServerSortMode"
                       Value="Filters.SortBy"
                       ValueChanged="OnSortChanged"
                       Variant="Variant.Text"
                       Margin="Margin.Dense"
                       Dense="true"
                       Class="server-toolbar__sort">
                <MudSelectItem Value="ServerSortMode.Players">Players</MudSelectItem>
                <MudSelectItem Value="ServerSortMode.Name">Name</MudSelectItem>
                <MudSelectItem Value="ServerSortMode.Ping">Ping</MudSelectItem>
            </MudSelect>

            <MudChipSet T="string" Class="server-toolbar__filters">
                <MudChip OnClick="ToggleHideEmpty"
                         Color="@(Filters.HideEmpty ? Color.Primary : Color.Default)"
                         Variant="@(Filters.HideEmpty ? Variant.Filled : Variant.Text)"
                         Size="Size.Small">
                    Hide empty
                </MudChip>

                <MudChip OnClick="ToggleHideFull"
                         Color="@(Filters.HideFull ? Color.Primary : Color.Default)"
                         Variant="@(Filters.HideFull ? Variant.Filled : Variant.Text)"
                         Size="Size.Small">
                    Hide full
                </MudChip>
            </MudChipSet>

        </MudStack>

        <MudStack Row="true"
                  AlignItems="AlignItems.Center"
                  Spacing="1">

            @{
                var (statusText, statusColor) = GetStatusDisplay();
            }

            <MudTooltip Text="@statusText">
                <MudIcon Icon="@Icons.Material.Filled.Circle"
                         Color="statusColor"
                         Size="Size.Small" />
            </MudTooltip>

            <MudText Typo="Typo.caption"
                     Color="Color.Secondary">
                @FilteredCount / @TotalCount
            </MudText>

            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                           Color="Color.Default"
                           Variant="Variant.Text"
                           Size="Size.Small"
                           Disabled="@IsRefreshing"
                           OnClick="OnRefresh"
                           Class="@(IsRefreshing ? "mud-spinner" : "")" />
        </MudStack>

    </MudStack>

    @if (AvailableRPTags.Count > 0)
    {
        <MudText Typo="Typo.subtitle2" Class="mt-4">
            RP Tags
        </MudText>
        <MudStack Row="true"
                  Wrap="Wrap.Wrap"
                  Spacing="1"
                  Class="mt-2">
            @foreach (var rpTag in AvailableRPTags)
            {
                var selected = Filters.SelectedRP.Contains(rpTag);
                <MudChip T="string"
                         Text="@rpTag"
                         Size="Size.Small"
                         Color="@(selected ? Color.Primary : Color.Default)"
                         Variant="@(selected ? Variant.Filled : Variant.Text)"
                         OnClick="@(() => ToggleRP(rpTag))" />
            }
        </MudStack>
    }

    @if (AvailableLangTags.Count > 0)
    {
        <MudText Typo="Typo.subtitle2" Class="mt-4">
            Language
        </MudText>
        <MudStack Row="true"
                  Wrap="Wrap.Wrap"
                  Spacing="1"
                  Class="mt-2">
            @foreach (var lang in AvailableLangTags)
            {
                var selected = Filters.SelectedLang.Contains(lang);
                <MudChip T="string"
                         Text="@lang"
                         Size="Size.Small"
                         Color="@(selected ? Color.Primary : Color.Default)"
                         Variant="@(selected ? Variant.Filled : Variant.Text)"
                         OnClick="@(() => ToggleLang(lang))" />
            }
        </MudStack>
    }

    @if (AvailableRegionTags.Count > 0)
    {
        <MudText Typo="Typo.subtitle2" Class="mt-4">
            Region
        </MudText>
        <MudStack Row="true"
                  Wrap="Wrap.Wrap"
                  Spacing="1"
                  Class="mt-2">
            @foreach (var region in AvailableRegionTags)
            {
                var selected = Filters.SelectedRegion.Contains(region);
                <MudChip T="string"
                         Text="@region"
                         Size="Size.Small"
                         Color="@(selected ? Color.Primary : Color.Default)"
                         Variant="@(selected ? Variant.Filled : Variant.Text)"
                         OnClick="@(() => ToggleRegion(region))" />
            }
        </MudStack>
    }

</MudPaper>