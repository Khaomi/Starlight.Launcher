<MudPaper Class="pa-4 mb-2" Outlined="true" Elevation="0">
    <div class="d-flex align-center">
        <MudIcon Icon="@Icon" Class="mr-4" />
        <div class="flex-grow-1">
            <MudText Typo="Typo.body1">@Title</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                @Description
            </MudText>
        </div>
        <MudTooltip Text="@AddButtonTooltip">
            <MudIconButton Icon="@Icons.Material.Filled.Add"
                           Color="Color.Primary"
                           OnClick="OnAddButtonPressed" />
        </MudTooltip>
    </div>
    @if (Values.Count == 0)
    {
        <MudPaper Class="pa-4 d-flex align-center justify-center"
                  Outlined="true"
                  Elevation="0"
                  Style="border-style: dashed;">
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                @EmptyValuesString
            </MudText>
        </MudPaper>
    }
    else
    {
        <MudStack Spacing="2">
            @for (var i = 0; i < Values.Count; i++)
            {
                var index = i;
                var value = Values[index];

                <div class="d-flex align-center gap-2">
                    <MudTooltip Text="@_localization["settings-alternative-selector-list-option-select"]">
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(index == _selectedIndex ? Color.Primary : Color.Default)"
                                 Variant="Variant.Filled"
                                 OnClick="@(() => Select(index))">
                            @if (index == _selectedIndex)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                            }
                            else
                            {
                                @(index + 1)
                            }
                        </MudChip>
                    </MudTooltip>

                    <MudTextField T="string"
                                  Value="@value"
                                  ValueChanged="@(v => OnValueChanged(v, index))"
                                  Immediate="true"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="@TextFieldLabel"
                                  Placeholder="https://example.com"
                                  Validation="@(new Func<string, string?>(ValidateUrl))"
                                  Class="flex-grow-1" />

                    <MudTooltip Text="@_localization["settings-alternative-selector-list-option-remove"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => RemoveAt(index))" />
                    </MudTooltip>
                </div>
            }
        </MudStack>
    }
</MudPaper>
