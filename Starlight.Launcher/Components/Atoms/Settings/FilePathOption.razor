<MudPaper Class="pa-4 mb-2" Outlined="true" Elevation="0">
    <div class="d-flex align-center">
        <MudIcon Icon="@Icon" Class="mr-4" />
        <div class="flex-grow-1">
            <MudText Typo="Typo.body1">@Title</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                @Description
            </MudText>
        </div>
    </div>
    <MudTextField T="string"
                  Value="Value"
                  ValueChanged="OnValueChanged"
                  Label="@Label"
                  HelperText="@Helper"
                  HelperTextOnFocus="HelperOnFocus"
                  ReadOnly="@(!AllowManualInput)"
                  Variant="Variant.Outlined"
                  Adornment="Adornment.End"
                  AdornmentIcon="@Icons.Material.Filled.FolderOpen"
                  AdornmentAriaLabel="Browse"
                  OnAdornmentClick="BrowseAsync" />
</MudPaper>
