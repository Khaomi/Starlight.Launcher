<MudPaper Class="pa-4 mb-2" Outlined="true" Elevation="0">
    <div class="d-flex align-center">
        <MudIcon Icon="@Icon" Class="mr-4" />
        <div class="flex-grow-1">
            <MudText Typo="Typo.body1">@Title</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                @Description
            </MudText>
        </div>
    </div>
    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
        <MudTextField T="string"
                      Class="flex-grow-1"
                      Value="Value"
                      ValueChanged="OnValueChanged"
                      Label="@Label"
                      HelperText="@Helper"
                      ReadOnly="@(!AllowManualInput)"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.FolderOpen"
                      OnAdornmentClick="BrowseAsync" />
        @if (ShowOpenButton)
        {
            <MudTooltip Text="@_localization["settings-file-path-option-tooltip"]">
                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                               OnClick="OpenFolderAsync" />
            </MudTooltip>
        }
    </MudStack>
</MudPaper>
