@using Starlight.Launcher.Services.Localization
@inject LocalizationManager Localization

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body1">
            @Localization["settings-development-tab-alert-description"]
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton onclick="Cancel" Color="Color.Secondary">Cancel</MudButton>
        <MudButton OnClick="Success" Color="Color.Primary">OK</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    public event Action? OnCancel;
    public event Action? OnSuccess;

    private void Success()
    {
        OnSuccess?.Invoke();
        MudDialog.Close();
    }

    private void Cancel()
    {
        OnCancel?.Invoke();
        MudDialog.Cancel();
    }
}
