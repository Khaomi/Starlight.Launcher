<MudPaper Class="pa-4 mb-2" Outlined="true" Elevation="0">
    <div class="d-flex align-center">
        <MudIcon Icon="@Icon" Class="mr-4" />
        <div class="flex-grow-1">
            <MudText Typo="Typo.body1">@Title</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">@Description</MudText>
        </div>
    </div>
    <div class="d-flex gap-2 mt-2">
        <MudNumericField T="int" Value="Days"    ValueChanged="SetDays"    Label="@DaysLabel"    Min="0"            Variant="Variant.Outlined" Color="Color.Primary" />
        <MudNumericField T="int" Value="Hours"   ValueChanged="SetHours"   Label="@HoursLabel"   Min="0" Max="23"   Variant="Variant.Outlined" Color="Color.Primary" />
        <MudNumericField T="int" Value="Minutes" ValueChanged="SetMinutes" Label="@MinutesLabel" Min="0" Max="59"   Variant="Variant.Outlined" Color="Color.Primary" />
        <MudNumericField T="int" Value="Seconds" ValueChanged="SetSeconds" Label="@SecondsLabel" Min="0" Max="59"   Variant="Variant.Outlined" Color="Color.Primary" />
    </div>
</MudPaper>