@using Starlight.Launcher.Services

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-3">
            <MudIcon Icon="@Icons.Material.Filled.SystemUpdateAlt" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Updating launcher</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="connect-dialog">
            @switch (_phase)
            {
                case Phase.Failed:
                    <MudAlert Severity="Severity.Error">@_error</MudAlert>
                    break;

                case Phase.Done:
                    <MudAlert Severity="Severity.Success" Dense="true">
                        Download complete. The installer will now open and the launcher will close.
                    </MudAlert>
                    break;

                default:
                    <div class="d-flex flex-column gap-3 py-2">
                        <div class="d-flex align-end justify-space-between">
                            <MudText Class="connect-meta">
                                @(_phase == Phase.Downloading ? "Downloading update…" : "Preparing…")
                            </MudText>
                            @if (_hasDeterminateProgress)
                            {
                                <span class="connect-percent">@_percent.ToString("0")%</span>
                            }
                        </div>

                        <div class="dl-bar">
                            @if (_hasDeterminateProgress)
                            {
                                <div class="dl-bar-fill" style="width:@_percentCss%"></div>
                            }
                            else
                            {
                                <div class="dl-bar-fill indeterminate"></div>
                            }
                        </div>

                        @if (_total > 0)
                        {
                            <div class="d-flex align-center justify-space-between connect-meta">
                                <MudText Typo="Typo.caption">@Format(_downloaded) / @Format(_total)</MudText>
                                @if (_haveSpeed && _smoothedBytesPerSec > 1)
                                {
                                    <MudText Typo="Typo.caption">
                                        @Format((long)_smoothedBytesPerSec)/s@(_eta is { } eta ? $" · {eta} left" : "")
                                    </MudText>
                                }
                            </div>
                        }
                    </div>
                    break;
            }
        </div>
    </DialogContent>
    <DialogActions>
        @if (_phase == Phase.Failed)
        {
            <MudButton OnClick="Close">Close</MudButton>
        }
        else if (_phase != Phase.Done)
        {
            <MudButton Color="Color.Error" OnClick="Cancel">Cancel</MudButton>
        }
    </DialogActions>
</MudDialog>
