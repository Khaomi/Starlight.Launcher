@using Starlight.Launcher.Services.Localization

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            @_localization.GetString("changelog-title", ("version", Version))
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudPaper Class="pa-2" Style="max-height:60vh; overflow-y:auto;" Elevation="0">
            @if (string.IsNullOrWhiteSpace(Notes))
            {
                <MudText>@_localization["changelog-empty"]</MudText>
            }
            else
            {
                <MudMarkdown Value="@Notes" />
            }
        </MudPaper>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="Close">
            @_localization["changelog-close"]
        </MudButton>
    </DialogActions>
</MudDialog>
