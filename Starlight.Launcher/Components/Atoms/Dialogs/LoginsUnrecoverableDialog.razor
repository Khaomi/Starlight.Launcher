@using Starlight.Launcher.Services.Localization

<MudDialog>
    <DialogContent>

        <MudText Typo="Typo.h6">
            @_localization["logins-unrecoverable-dialog-title"]
        </MudText>

        <MudList T="string" Dense="true">
            @foreach (var login in Logins)
            {
                <MudListItem>@login</MudListItem>
            }
        </MudList>

    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Close">
            @_localization["logins-unrecoverable-dialog-confirm"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code
{
    [Inject] private LocalizationManager _localization { get; set; } = default!;

    [Parameter]
    public IEnumerable<string> Logins { get; set; } = [];

    [CascadingParameter]
    private IMudDialogInstance Dialog { get; set; } = default!;

    private void Close() => Dialog.Close();
}
