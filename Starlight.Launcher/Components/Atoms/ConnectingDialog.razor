@using System.ComponentModel
@using System.Threading
@using Starlight.Launcher.Services
@using Robust.Launcher.Api.Models.Data
@using static Starlight.Launcher.Services.Connector
@implements IDisposable
@inject Connector Connector
@inject Updater Updater

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Title</MudText>
    </TitleContent>
    <DialogContent>
        @switch (Connector.Status)
        {
            case ConnectionStatus.AwaitingPrivacyPolicyAcceptance:
                <MudText Class="mb-2">This server requires you to accept its privacy policy before connecting.</MudText>
                @if (Connector.PrivacyPolicyInfo is { } pp)
                {
                    <MudText Typo="Typo.body2">@pp.Identifier (v@pp.Version)</MudText>
                    @* Render the actual policy link / text here from whatever fields ServerPrivacyPolicyInfo exposes. *@
                }
                @if (Connector.PrivacyPolicyDifferentVersion)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                        The policy has changed since you last accepted it.
                    </MudAlert>
                }
                break;

            case ConnectionStatus.Updating:
                <MudText Class="mb-2">@StatusText</MudText>
                @if (Updater.Progress is { total: > 0 } p)
                {
                    <MudProgressLinear Color="Color.Primary" Value="@Percent" Class="my-2" />
                    <MudText Typo="Typo.caption">
                        @Format(p.downloaded) / @Format(p.total)
                        @if (Updater.Speed is { } s)
                        {
                            <text> — @(Format(s))/s</text>
                        }
                    </MudText>
                }
                else
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-2" />
                }
                break;

            case ConnectionStatus.ConnectionFailed:
            case ConnectionStatus.UpdateError:
            case ConnectionStatus.NotAContentBundle:
                <MudAlert Severity="Severity.Error">@StatusText</MudAlert>
                break;

            case ConnectionStatus.ClientExited when Connector.ClientExitedBadly:
                <MudAlert Severity="Severity.Error">The game closed unexpectedly.</MudAlert>
                break;

            default:
                <div class="d-flex align-center gap-3">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
                    <MudText>@StatusText</MudText>
                </div>
                break;
        }
    </DialogContent>
    <DialogActions>
        @if (Connector.Status == ConnectionStatus.AwaitingPrivacyPolicyAcceptance)
        {
            <MudButton OnClick="@(() => Decide(PrivacyPolicyAcceptResult.Denied))">Decline</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       OnClick="@(() => Decide(PrivacyPolicyAcceptResult.Accepted))">
                Accept &amp; continue
            </MudButton>
        }
        else if (IsTerminal)
        {
            <MudButton OnClick="Close">Close</MudButton>
        }
        else
        {
            <MudButton Color="Color.Error" OnClick="Cancel">Cancel</MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Address { get; set; } = "";

    [Parameter] public FileResult? ContentBundle { get; set; }

    private readonly CancellationTokenSource _cts = new();
    private Timer? _pollTimer;

    private string Title => ContentBundle is { } f
        ? $"Launching {f.FileName}"
        : $"Connecting to {Address}";

    private double Percent =>
        Updater.Progress is { total: > 0 } p ? (double)p.downloaded / p.total * 100.0 : 0;

    private bool IsTerminal => Connector.Status is
        ConnectionStatus.ConnectionFailed
        or ConnectionStatus.UpdateError
        or ConnectionStatus.NotAContentBundle
        or ConnectionStatus.Cancelled
        or ConnectionStatus.ClientExited;

    // Map the coarse connection phase + the updater's own status to a human string.
    private string StatusText => Connector.Status switch
    {
        ConnectionStatus.Connecting => "Contacting server…",
        ConnectionStatus.Updating => Updater.Status switch
        {
            Updater.UpdateStatus.DownloadingEngineVersion => "Downloading engine…",
            Updater.UpdateStatus.DownloadingEngineModules => "Downloading engine modules…",
            Updater.UpdateStatus.DownloadingClientUpdate => "Downloading game files…",
            Updater.UpdateStatus.LoadingIntoDb => "Installing…",
            Updater.UpdateStatus.LoadingContentBundle => "Loading content bundle…",
            Updater.UpdateStatus.Verifying => "Verifying…",
            Updater.UpdateStatus.CommittingDownload => "Finishing up…",
            _ => "Checking for updates…"
        },
        ConnectionStatus.StartingClient => "Starting the game…",
        ConnectionStatus.ClientRunning => "Game is running.",
        ConnectionStatus.ConnectionFailed => "Could not reach the server.",
        ConnectionStatus.UpdateError => "Update failed. See the logs for details.",
        ConnectionStatus.NotAContentBundle => "This file isn't a valid content bundle.",
        ConnectionStatus.Cancelled => "Cancelled.",
        _ => "Starting…"
    };

    protected override void OnInitialized()
    {
        Connector.PropertyChanged += OnConnectorChanged;

        _pollTimer = new Timer(_ => InvokeAsync(StateHasChanged), null,
            TimeSpan.Zero, TimeSpan.FromMilliseconds(250));

        // Fire-and-forget: Status drives the UI from here on.
        if (ContentBundle is { } bundle)
            Connector.LaunchContentBundle(bundle, _cts.Token);
        else
            Connector.Connect(Address, _cts.Token);
    }

    private void OnConnectorChanged(object? sender, PropertyChangedEventArgs e)
    {
        InvokeAsync(() =>
        {
            // Game launched fine — close the dialog (and hide/minimize the launcher window).
            if (Connector.Status == ConnectionStatus.ClientRunning)
                MudDialog.Close();

            StateHasChanged();
        });
    }

    private void Decide(PrivacyPolicyAcceptResult result) => Connector.ConfirmPrivacyPolicy(result);

    private void Cancel()
    {
        _cts.Cancel();
        MudDialog.Cancel();
    }

    private void Close() => MudDialog.Close();

    private static string Format(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB"];
        double v = bytes;
        var i = 0;
        while (v >= 1024 && i < units.Length - 1)
        {
            v /= 1024;
            i++;
        }
        return $"{v:0.#} {units[i]}";
    }

    public void Dispose()
    {
        Connector.PropertyChanged -= OnConnectorChanged;
        _pollTimer?.Dispose();

        // Once the client is actually running, the connect task is just awaiting the game's
        // exit — don't touch the token (cancelling would mark a healthy launch as cancelled),
        // and don't dispose the CTS while it's still in use.
        if (Connector.Status != ConnectionStatus.ClientRunning)
        {
            if (!_cts.IsCancellationRequested)
                _cts.Cancel();
            _cts.Dispose();
        }
    }
}
