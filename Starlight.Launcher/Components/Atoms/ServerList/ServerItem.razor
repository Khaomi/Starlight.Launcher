@using Robust.Launcher.Api.Models.ServerStatus

<div class="server-card @(_expanded ? "server-card--expanded" : null)" @onclick="HandleClick">
    <div class="server-card__row">

        <div class="server-card__primary">
            <MudIcon Icon="@Icons.Material.Rounded.ChevronRight" Class="server-card__chevron" />
            <div class="server-card__title-block">
                <div class="server-card__title-line">
                    <span class="server-card__name">@(Data.Name ?? Data.Address)</span>
                    @if (Data.StatusInfo == ServerStatusInfoCode.Fetching)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                             Color="Color.Primary" Class="server-card__spinner" />
                    }
                </div>

                @if (_displayTags is { Count: > 0 })
                {
                    <div class="server-card__tags">
                        @foreach (var tag in _displayTags)
                        {
                            <span class="server-card__tag">@tag</span>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="server-card__meta">
            @if (_pingMs is { } ping)
            {
                <div class="server-card__ping @_pingClass" title="@($"{ping} ms")">
                    <span class="server-card__ping-dot"></span>
                    <span class="server-card__ping-text">@ping ms</span>
                </div>
            }

            @if (_roundStatusText is not null || _roundTime is not null)
            {
                <div class="server-card__round">
                    @if (_roundStatusText is not null)
                    {
                        <span class="server-card__round-status">@_roundStatusText</span>
                    }
                    @if (_roundTime is not null)
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Schedule" Class="server-card__round-icon" />
                        <span class="server-card__round-time">@_roundTime</span>
                    }
                </div>
            }

            <div class="server-card__players" title="@($"{Data.PlayerCount} / {Data.SoftMaxPlayerCount}")">
                <MudIcon Icon="@Icons.Material.Filled.Person" Class="server-card__players-icon" />
                <span class="server-card__players-text">
                    <strong>@Data.PlayerCount</strong><span class="server-card__players-slash">/</span>@Data.SoftMaxPlayerCount
                </span>
            </div>
        </div>

        <div class="server-card__play" @onclick:stopPropagation="true">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Rounded.PlayArrow"
                       OnClick="Play" Class="server-card__play-btn">
                @_localization["servers-list-item-play"]
            </MudButton>
        </div>

        <div class="server-card__fav" @onclick:stopPropagation="true">
            <MudTooltip Color="Color.Primary" Text="@_localization["servers-list-item-favorites"]">
                <MudIconButton Icon="@(IsInFavorites ? Icons.Material.Rounded.Star : Icons.Material.Rounded.StarBorder)"
                               Color="Color.Primary" OnClick="HandleFavorites" />
            </MudTooltip>
        </div>
    </div>

    <MudCollapse Expanded="_expanded">
        <div class="server-card__details">
            <div class="server-card__description">
                @if (!string.IsNullOrWhiteSpace(Data.Description))
                {
                    @Data.Description
                }
                else if (Data.StatusInfo == ServerStatusInfoCode.Error)
                {
                    <span class="server-card__description--error">Could not load details</span>
                }
                else if (Data.StatusInfo is ServerStatusInfoCode.NotFetched or ServerStatusInfoCode.Fetching)
                {
                    <span class="server-card__description--muted">Loading…</span>
                }
            </div>

            @if (Data.Links is { Length: > 0 })
            {
                <div class="server-card__links">
                    @foreach (var link in Data.Links)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                 Icon="@ParseIcon(link.Icon)"
                                 OnClick="@(() => OnInfoClick(link.Url))">@link.Name</MudChip>
                    }
                </div>
            }
        </div>
    </MudCollapse>
</div>
