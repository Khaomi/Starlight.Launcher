@using Robust.Launcher.Api.Models.ServerStatus
@implements IDisposable

<div class="@RowClass" @onclick="HandleClick">
    <div class="server-row__main">
        <div class="server-row__title-line">
            <MudText class="server-row__name" Typo="Typo.subtitle1">@(Data.Name ?? Data.Address)</MudText>
            @if (Data.StatusInfo == ServerStatusInfoCode.Fetching)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary"
                                     Class="server-row__spinner" />
            }
        </div>
        <MudCollapse Expanded="Expanded">
            <div class="server-row__description">
                @if (!string.IsNullOrWhiteSpace(Data.Description))
                {
                    @Data.Description
                }
                else if (Data.StatusInfo == ServerStatusInfoCode.Error)
                {
                    <span class="server-row__description--error">Could not load details</span>
                }
                else if (Data.StatusInfo == ServerStatusInfoCode.NotFetched || Data.StatusInfo == ServerStatusInfoCode.Fetching)
                {
                    <span class="server-row__description--muted">Loading…</span>
                }
            </div>

            @if (Data.Links != null && Data.Links.Length > 0)
            {
                <div>
                    @foreach (var link in Data.Links)
                    {
                        <MudChip T="string" Icon="@ParseIcon(link.Icon)" OnClick="() => OnInfoClick(link.Url)">@link.Name</MudChip>
                    }
                </div>
            }
        </MudCollapse>
    </div>

    <div class="server-row__meta">
        @if (DisplayTags is { Count: > 0 })
        {
            <div class="server-row__tags">
                @foreach (var tag in DisplayTags)
                {
                    <span class="server-row__tag">@tag</span>
                }
            </div>
        }
        <div class="server-row__players">
            <MudIcon Icon="@Icons.Material.Filled.Person" Class="server-row__players-icon" />
            <span class="server-row__players-text">
                <strong>@Data.PlayerCount</strong><span class="server-row__players-slash">/</span>@Data.SoftMaxPlayerCount
            </span>
        </div>
        <div class="server-row__favorite">
            <MudTooltip Color="@Color.Primary" Text="@Localization["servers-list-item-favorites"]">
                <MudIconButton Icon="@(IsInFavorites ? Icons.Material.Rounded.Star : Icons.Material.Rounded.StarBorder)"
                               Color="Color.Primary"
                               OnClick="HandleFavorites" />
            </MudTooltip>
        </div>
    </div>
</div>