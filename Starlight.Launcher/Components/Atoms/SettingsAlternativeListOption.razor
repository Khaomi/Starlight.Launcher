<MudPaper Class="pa-4" Outlined="true" Elevation="0">
    <div class="d-flex align-center">
        <MudIcon Icon="@Icon" Class="mr-4" />
        <div class="flex-grow-1">
            <MudText Typo="Typo.body1">@Title</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                @Description
            </MudText>
        </div>
        <MudTooltip Text="Add hub">
            <MudIconButton Icon="@Icons.Material.Filled.Add"
                           Color="Color.Primary"
                           OnClick="OnAddButtonPressed" />
        </MudTooltip>
    </div>
    @if (Value.Count == 0)
    {
        <MudPaper Class="pa-4 d-flex align-center justify-center"
                  Outlined="true"
                  Elevation="0"
                  Style="border-style: dashed;">
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                No hubs configured. Click + to add one.
            </MudText>
        </MudPaper>
    }
    else
    {
        <MudStack Spacing="2">
            @for (var i = 0; i < Value.Count; i++)
            {
                var index = i;
                var item = Value[index];

                <div class="d-flex align-center gap-2">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@(index == 0 ? Color.Primary : Color.Default)"
                             Variant="Variant.Filled">
                        @(index + 1)
                    </MudChip>

                    <MudTextField T="string"
                                  Value="@item.Url"
                                  ValueChanged="@(v => OnValueChanged(v, index))"
                                  Immediate="true"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="Hub URL"
                                  Placeholder="https://example.com"
                                  Validation="@(new Func<string, string?>(ValidateUrl))"
                                  Class="flex-grow-1" />

                    <MudTooltip Text="Move up">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward"
                                       Size="Size.Small"
                                       Disabled="@(index == 0)"
                                       OnClick="@(() => MoveUp(index))" />
                    </MudTooltip>

                    <MudTooltip Text="Move down">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward"
                                       Size="Size.Small"
                                       Disabled="@(index == Value.Count - 1)"
                                       OnClick="@(() => MoveDown(index))" />
                    </MudTooltip>

                    <MudTooltip Text="Remove">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => RemoveAt(index))" />
                    </MudTooltip>
                </div>
            }
        </MudStack>
    }
</MudPaper>