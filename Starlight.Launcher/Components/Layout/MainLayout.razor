@using Starlight.Launcher.Services.Settings
@using Starlight.Launcher.Models.Settings
@using Starlight.Launcher.Services.State

@inherits LayoutComponentBase

@inject SettingsService Settings
@inject AppState State
@inject NavigationManager Navigation
@implements IDisposable

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode"/>
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        @if (_bottomNavigation)
        {
            <MudText Typo="Typo.h5" Class="ml-3">STARLIGHT</MudText>
        }
    </MudAppBar>

    @if (!_bottomNavigation)
    {
        <MudDrawer Elevation="1" ClipMode="DrawerClipMode.Never" Open="true" Variant="@DrawerVariant.Responsive">
            <MudDrawerHeader>
                <MudText Typo="Typo.h5" Class="ml-3">STARLIGHT</MudText>
            </MudDrawerHeader>
            <MudNavMenu Dense="true" Margin="Margin.Normal" Rounded="true" Color="Color.Primary" Class="pa-2">
                <MudNavLink Icon="@Icons.Material.Filled.Home" Href="/" Match="NavLinkMatch.All">
                    Home
                </MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.Settings" Href="/settings" Match="NavLinkMatch.All">
                    Settings
                </MudNavLink>
            </MudNavMenu>
        </MudDrawer>
    }

    <MudMainContent Class="@(_bottomNavigation ? "pb-16" : "")">
        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <MudAlert Severity="Severity.Error" Class="ma-4">
                    <MudText>Something went wrong. Please try refreshing the page.</MudText>
                </MudAlert>
            </ErrorContent>
        </ErrorBoundary>
    </MudMainContent>

    @if (_bottomNavigation)
    {
        <MudAppBar Bottom="true" Fixed="true" Elevation="3">
            <div class="bottom-nav">
                <NavLink href="/" Match="NavLinkMatch.All" class="bottom-nav-item" ActiveClass="active">
                    <div class="nav-inner">
                        <MudIcon Icon="@Icons.Material.Filled.Home" Color="@(IsActive("/", NavLinkMatch.All) ? Color.Primary : Color.Default)" Size="Size.Medium" />
                        <span>Home</span>
                    </div>
                </NavLink>
                <NavLink href="/settings" Match="NavLinkMatch.Prefix" class="bottom-nav-item" ActiveClass="active">
                    <div class="nav-inner">
                        <MudIcon Icon="@Icons.Material.Filled.Settings" Color="@(IsActive("/settings", NavLinkMatch.All) ? Color.Primary : Color.Default)" Size="Size.Medium" />
                        <span>Settings</span>
                    </div>
                </NavLink>
            </div>
        </MudAppBar>
    }

</MudLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

