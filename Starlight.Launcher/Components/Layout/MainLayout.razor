@using Starlight.Launcher.Models.Data
@inherits LayoutComponentBase

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        @if (_elementPosition == ElementPosition.Bottom || _isSmallScreen)
        {
            <MudText Typo="Typo.h5" Class="ml-3">STARLIGHT</MudText>
            <MudSpacer />
            <MudIconButton />
            <MudTooltip Text="@_localization["main-layout-auth-tab"]">
                <MudIconButton Href="/auth" Icon="@Icons.Material.Filled.People" Size="Size.Medium" />
            </MudTooltip>
        }
        else if (_elementPosition == ElementPosition.Top)
        {
            <HorizontalNavBar />
        }
    </MudAppBar>

    @if ((_elementPosition == ElementPosition.Left || _elementPosition == ElementPosition.Right) && !_isSmallScreen)
    {
        <MudDrawer Anchor="_elementPosition == ElementPosition.Left ? Anchor.Left : Anchor.Right" Elevation="1" ClipMode="DrawerClipMode.Never" Open="true" Variant="@DrawerVariant.Responsive">
            <VerticalNavBar />
        </MudDrawer>
    }

    <MudMainContent Class="@(_elementPosition is ElementPosition.Bottom or ElementPosition.Top || _isSmallScreen ? "has-bottom-nav" : "")">
        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <MudAlert Severity="Severity.Error" Class="ma-4">
                    <MudText>Something went wrong. Please try refreshing the page.</MudText>
                </MudAlert>
            </ErrorContent>
        </ErrorBoundary>
    </MudMainContent>

    @if (_elementPosition is ElementPosition.Bottom or ElementPosition.Top || _isSmallScreen)
    {
        <MudAppBar Bottom="true" Elevation="3">
            @if (_elementPosition == ElementPosition.Top)
            {
                <MudTooltip Text="@_localization["main-layout-auth-tab"]">
                    <MudIconButton Href="/auth" Icon="@Icons.Material.Filled.People" Size="Size.Medium" />
                </MudTooltip>
                <MudSpacer />
                <MudText Typo="Typo.h5" Class="mr-3">STARLIGHT</MudText>
            }
            else if (_elementPosition == ElementPosition.Bottom)
            {
                <HorizontalNavBar />
            }
        </MudAppBar>
    }

</MudLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
