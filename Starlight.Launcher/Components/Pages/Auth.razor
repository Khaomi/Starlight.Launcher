@page "/auth"
@using Robust.Launcher.Api.Models
@using Starlight.Launcher.Api.Models

<div class="auth-bg">
    <MudContainer MaxWidth="MaxWidth.Small" Class="auth-wrapper">
        <MudPaper Class="pa-8 auth-card" Elevation="0">
            <div @key="_mode" class="mode-fade">
                @switch (_mode)
                {
                    case Mode.AccountList:
                        <MudText Typo="Typo.h5" Class="mb-4"> @_localization["auth-menu-accounts-mode"] </MudText>

                        @if (_loginManager.Logins.Count == 0)
                        {
                            <MudStack AlignItems="AlignItems.Center" Class="empty-state py-8">
                                <MudIcon Icon="@Icons.Material.Outlined.PersonOff"
                                         Class="empty-icon mb-2" />
                                <MudText Typo="Typo.body1">@_localization["auth-menu-no-accounts"]</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                    @_localization["auth-menu-no-accounts-hint"]
                                </MudText>
                            </MudStack>
                        }
                        else
                        {
                            <MudList T = "LoggedInAccount" Dense = "true">
                                @foreach (var account in _loginManager.Logins)
                                {
                                    var acc = account;
                                    var isActive = _loginManager.ActiveAccountId == acc.UserId;

                                    <MudListItem T="LoggedInAccount" Class="my-1 account-row">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Style="width:100%">

                                            <MudAvatar Color="Color.Primary" Size="Size.Medium">
                                                @(string.IsNullOrEmpty(acc.LoginInfo.Username)
                                                    ? "?"
                                                    : char.ToUpperInvariant(acc.LoginInfo.Username[0]).ToString())
                                            </MudAvatar>

                                            <MudStack Spacing="0" Style="flex:1 1 auto; min-width:0">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudText Typo="Typo.body1" Style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap">
                                                        @acc.LoginInfo.Username
                                                    </MudText>
                                                    @if (isActive)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="ml-1">
                                                            @_localization["auth-menu-active-chip"]
                                                        </MudChip>
                                                    }
                                                    @if (acc.LoginInfo.DiscordToken != null)
                                                    {
                                                        <MudTooltip Text="@_localization["auth-menu-discord-linked-tooltip"]">
                                                            <MudIcon Icon="@Icons.Custom.Brands.Discord" Size="Size.Small" Color="Color.Info" />
                                                        </MudTooltip>
                                                    }
                                                </MudStack>

                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mt-1">
                                                    <span class="status-dot" style="background:var(--mud-palette-@(StatusCssVar(acc.Status)))"></span>
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                        @StatusLabel(acc.Status)
                                                    </MudText>
                                                </MudStack>
                                            </MudStack>

                                            @if (acc.Status == AccountLoginStatus.Expired)
                                            {
                                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Warning"
                                                           Style="flex:0 0 auto"
                                                           OnClick="() => BeginRelogin(acc)">
                                                    @_localization["auth-menu-login-again-button"]
                                                </MudButton>
                                            }
                                            else
                                            {
                                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                                           Style="flex:0 0 auto"
                                                           Disabled="@(isActive || _busy)"
                                                           OnClick="() => SelectAccount(acc)">
                                                    @_localization["auth-menu-select-button"]
                                                </MudButton>
                                            }

                                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"
                                                     Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                                                     Disabled="_busy">
                                                @if (acc.Status != AccountLoginStatus.Expired
                                                     && acc.LoginInfo.Token != null
                                                     && acc.LoginInfo.DiscordToken == null)
                                                {
                                                    <MudMenuItem Icon="@Icons.Custom.Brands.Discord" IconColor="Color.Info"
                                                                 OnClick="() => LinkDiscord(acc)">
                                                        @_localization["auth-menu-link-discord-button"]
                                                    </MudMenuItem>
                                                }
                                                <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error"
                                                             OnClick="() => RemoveAccount(acc)">
                                                    @_localization["auth-menu-delete-account-button"]
                                                </MudMenuItem>
                                            </MudMenu>

                                        </MudStack>
                                    </MudListItem>
                                    <MudDivider />
                                }
                            </MudList>
                        }

                        <MudButton Variant = "Variant.Filled"
                          Color = "Color.Primary"
                          FullWidth = "true"
                          StartIcon = "@Icons.Material.Filled.Add"
                          Class = "mt-4"
                          OnClick = "GoToSignIn" >
                            @_localization["auth-menu-add-account-button"]
                        </MudButton>
                        break;

                    case Mode.SignIn:
                        <MudStack Row = "true" AlignItems = "AlignItems.Center" Class = "mb-4">
                            @if (_loginManager.Logins.Count > 0)
                            {
                                <MudIconButton Icon = "@Icons.Material.Filled.ArrowBack"
                                  OnClick = "BackToAccountList"
                                  Disabled = "_busy"/>
                            }

                            <MudText Typo="Typo.h5">
                                @(_relogUserId.HasValue ? _localization["auth-menu-signin-login-again"] : _localization["auth-menu-signin-login"])
                            </MudText>
                        </MudStack>

                        <MudTextField @bind-Value = "_signInUsername"
                          Label="@_localization["auth-menu-username-label"]"
                          Variant = "Variant.Outlined"
                          Disabled = "@(_busy || _relogUserId.HasValue)"
                          Class = "mb-3"/>

                        <MudTextField @bind-Value = "_signInPassword"
                          Label="@_localization["auth-menu-password-label"]"
                          InputType="@(_showPwd ? InputType.Text : InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPwd ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                          OnAdornmentClick="() => _showPwd = !_showPwd"
                          Variant = "Variant.Outlined"
                          Disabled = "_busy"
                          Class = "mb-3"
                          OnKeyDown = "OnSignInKey"/>

                        @if (_signInTfaRequired)
                        {
                            <MudTextField @bind-Value = "_signInTfaCode"
                              Label="@_localization["auth-menu-2fa-label"]"
                              Variant = "Variant.Outlined"
                              Disabled = "_busy"
                              Class = "mb-3"
                              OnKeyDown = "OnSignInKey"/>
                        }

                        @if (!string.IsNullOrEmpty(_signInError))
                        {
                            <MudAlert Severity = "Severity.Error" Class = "mb-3"> @_signInError </MudAlert>
                        }

                        @if (_signInShowResend)
                        {
                            <MudButton Variant = "Variant.Text"
                              Color = "Color.Info"
                              FullWidth = "true"
                              Disabled = "_busy"
                              OnClick = "ResendConfirmation"
                              Class = "mb-3">
                                @_localization["auth-menu-resend-confirmation"]
                            </MudButton>
                        }

                        <MudButton Variant = "Variant.Filled"
                          Color = "Color.Primary"
                          FullWidth = "true"
                          Disabled = "_busy"
                          OnClick = "DoSignIn"
                          Class = "mb-3">
                            @if (_busy)
                            {
                                <MudProgressCircular Size = "Size.Small" Indeterminate = "true" Class = "mr-2"/>
                                <span>@_localization["auth-menu-signin-status-busy"]</span>
                            }
                            else
                            {
                                <span>@_localization["auth-menu-signin-status-wait"]</span>
                            }
                        </MudButton>

                        <MudDivider Class="my-3" />
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   FullWidth="true"
                                   StartIcon="@Icons.Custom.Brands.Discord"
                                   Disabled="_busy"
                                   OnClick="LoginWithDiscord"
                                   Class="mb-3">
                            @_localization["auth-menu-signin-method-discord"]
                        </MudButton>

                        <MudStack Row = "true" Justify = "Justify.SpaceBetween">
                            <MudButton Variant = "Variant.Text"
                              Disabled = "_busy"
                              OnClick = "() => SwitchMode(Mode.ForgotPassword)">
                                @_localization["auth-menu-signin-forgot-password"]
                            </MudButton>
                            <MudButton Variant = "Variant.Text"
                              Disabled = "_busy"
                              OnClick = "() => SwitchMode(Mode.Register)">
                                @_localization["auth-menu-registration"]
                            </MudButton>
                        </MudStack>
                        break;

                    case Mode.Register:
                        <MudStack Row = "true" AlignItems = "AlignItems.Center" Class = "mb-4">
                            <MudIconButton Icon = "@Icons.Material.Filled.ArrowBack"
                              OnClick = "() => SwitchMode(Mode.SignIn)"
                              Disabled = "_busy"/>
                            <MudText Typo = "Typo.h5"> @_localization["auth-menu-registration"] </MudText>
                        </MudStack>

                        @if (_registerSuccessMessage != null)
                        {
                            <MudAlert Severity = "Severity.Success" Class = "mb-3"> @_registerSuccessMessage </MudAlert>
                            <MudButton Variant = "Variant.Filled"
                              Color = "Color.Primary"
                              FullWidth = "true"
                              OnClick = "() => SwitchMode(Mode.SignIn)" >
                                @_localization["auth-menu-registration-signin"]
                            </MudButton>
                            return;
                        }

                        <MudTextField @bind-Value = "_registerUsername"
                          Label="@_localization["auth-menu-username-label"]"
                          Variant = "Variant.Outlined"
                          Disabled = "_busy"
                          Class = "mb-3"/>

                        <MudTextField @bind-Value = "_registerEmail"
                          Label="@_localization["auth-menu-email-label"]"
                          InputType = "InputType.Email"
                          Variant = "Variant.Outlined"
                          Disabled = "_busy"
                          Class = "mb-3"/>

                        <MudTextField @bind-Value = "_registerPassword"
                          Label="@_localization["auth-menu-password-label"]"
                          InputType = "InputType.Password"
                          Variant = "Variant.Outlined"
                          Disabled = "_busy"
                          Class = "mb-3"/>

                        <MudTextField @bind-Value = "_registerPasswordConfirm"
                          Label="@_localization["auth-menu-confirm-label"]"
                          InputType = "InputType.Password"
                          Variant = "Variant.Outlined"
                          Disabled = "_busy"
                          Class = "mb-3"/>

                        @if (_registerErrors != null && _registerErrors.Length > 0)
                        {
                            <MudAlert Severity = "Severity.Error" Class = "mb-3">
                                @foreach (var err in _registerErrors)
                                {
                                    <div> @err </div>
                                }
                            </MudAlert>
                        }

                        <MudButton Variant = "Variant.Filled"
                          Color = "Color.Primary"
                          FullWidth = "true"
                          Disabled = "_busy"
                          OnClick = "DoRegister">
                            @if (_busy)
                            {
                                <MudProgressCircular Size = "Size.Small" Indeterminate = "true" Class = "mr-2"/>
                                <span>@_localization["auth-menu-registration-status-busy"]</span>
                            }
                            else
                            {
                                <span>@_localization["auth-menu-registration-status-wait"]</span>
                            }
                        </MudButton>
                        break;

                    case Mode.ForgotPassword:
                        <MudStack Row = "true" AlignItems = "AlignItems.Center" Class = "mb-4">
                            <MudIconButton Icon = "@Icons.Material.Filled.ArrowBack"
                              OnClick = "() => SwitchMode(Mode.SignIn)"
                              Disabled = "_busy" />
                            <MudText Typo="Typo.h5">@_localization["auth-menu-forgotpassword"]</MudText>
                        </MudStack>

                        @if (_forgotSuccess)
                        {
                            <MudAlert Severity = "Severity.Success" Class = "mb-3">
                                @_localization["auth-menu-forgotpassword-alert"]
                            </MudAlert>
                            <MudButton Variant = "Variant.Filled"
                              Color = "Color.Primary"
                              FullWidth = "true"
                              OnClick = "() => SwitchMode(Mode.SignIn)">
                                @_localization["auth-menu-signin"]
                            </MudButton>
                            return;
                        }

                        <MudText Class="mb-3">@_localization["auth-menu-enter-email-label"]</MudText>

                        <MudTextField @bind-Value = "_forgotEmail"
                                      Label="@_localization["auth-menu-email-label"]"
                          InputType = "InputType.Email"
                          Variant = "Variant.Outlined"
                          Disabled = "_busy"
                          Class = "mb-3"/>

                        @if (!string.IsNullOrEmpty(_forgotError))
                        {
                            <MudAlert Severity = "Severity.Error" Class = "mb-3"> @_forgotError </MudAlert>
                        }

                        <MudButton Variant = "Variant.Filled"
                          Color = "Color.Primary"
                          FullWidth = "true"
                          Disabled = "_busy"
                          OnClick = "DoForgotPassword">
                            @if (_busy)
                            {
                                <MudProgressCircular Size = "Size.Small" Indeterminate = "true" Class = "mr-2"/>
                                <span>@_localization["auth-menu-forgotpassword-status-busy"]</span>
                            }
                            else
                            {
                                <span>@_localization["auth-menu-forgotpassword-status-wait"]</span>
                            }
                        </MudButton>
                        break;
                }
            </div>
        </MudPaper>
    </MudContainer>
</div>
