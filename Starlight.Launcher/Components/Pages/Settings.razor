@using Starlight.Launcher.Services.Settings
@using Starlight.Launcher.Services.State
@using Starlight.Launcher.Models.Settings

@page "/settings"

@inject SettingsService _settings;
@inject AppState _state;

<MudTabs Elevation="0" ApplyEffectsToContainer="true" Class="settings-tabs" PanelClass="pa-6">
    <MudTabPanel Text="General">
        <MudContainer MaxWidth="MaxWidth.Small" Class="pa-0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">Appearance</MudText>
            <SettingsBoolOption Value="DarkTheme" ValueChanged="OnThemeChanged" Title="Dark theme" Description="Use a darker color scheme across the app" Icon="@Icons.Material.Filled.DarkMode"/>
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">Layout</MudText>
            <SettingsBoolOption Value="BottomNavigation" ValueChanged="OnNavigationChanged" Title="Bottom navigation" Description="Show the navigation bar at the bottom of the screen" Icon="@Icons.Material.Filled.MenuOpen" />
        </MudContainer>
    </MudTabPanel>
</MudTabs>

@code {
    private bool DarkTheme = true;
    private bool BottomNavigation = true;

    protected override async Task OnInitializedAsync()
    {
        var settings = await _settings.GetSettingsAsync();
        DarkTheme = settings.Theme == AppTheme.Light ? false : true;
        BottomNavigation = settings.BottomNavigation;
    }

    private async Task OnNavigationChanged(bool value)
        => await OnBoolSettingChanged(value, v => BottomNavigation = v, (s, v) => s with { BottomNavigation = v });

    private async Task OnThemeChanged(bool value)
        => await OnBoolSettingChanged(value, v => DarkTheme = v, (s, v) => s with { Theme = v ? AppTheme.Dark : AppTheme.Light });

    private Task OnBoolSettingChanged(
        bool value,
        Action<bool> setLocal,
        Func<AppSettings, bool, AppSettings> update)
    {
        setLocal(value);

        return UpdateSetting(s => update(s, value));
    }

    private async Task UpdateSetting(Func<AppSettings, AppSettings> update)
    {
        var settings = await _settings.GetSettingsAsync();
        var newSettings = update(settings);
        await _settings.WriteSettingsAsync(newSettings);
        _state.CallUpdate();
    }
}