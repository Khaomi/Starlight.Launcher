@using Starlight.Launcher.Services.Settings
@using Starlight.Launcher.Services.State
@using Starlight.Launcher.Models.Settings

@page "/settings"

@inject SettingsService _settings;
@inject AppState _state;

<MudTabs Elevation="0" ApplyEffectsToContainer="true" Class="settings-tabs" PanelClass="pa-6">
    <MudTabPanel Text="General">
        <MudContainer MaxWidth="MaxWidth.Small" Class="pa-0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">Appearance</MudText>
            <MudPaper Class="pa-4 mb-4" Outlined="true" Elevation="0">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.DarkMode" Class="mr-4" />
                    <div class="flex-grow-1">
                        <MudText Typo="Typo.body1">Dark theme</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            Use a darker color scheme across the app
                        </MudText>
                    </div>
                    <MudSwitch T="bool"
                               Value="DarkTheme"
                               ValueChanged="OnThemeChanged"
                               Color="Color.Primary" />
                </div>
            </MudPaper>
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">Layout</MudText>
            <MudPaper Class="pa-4" Outlined="true" Elevation="0">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.MenuOpen" Class="mr-4" />
                    <div class="flex-grow-1">
                        <MudText Typo="Typo.body1">Bottom navigation</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            Show the navigation bar at the bottom of the screen
                        </MudText>
                    </div>
                    <MudSwitch T="bool"
                               Value="BottomNavigation"
                               ValueChanged="OnNavigationChanged"
                               Color="Color.Primary" />
                </div>
            </MudPaper>
        </MudContainer>
    </MudTabPanel>
</MudTabs>

@code {
    private bool DarkTheme = true;
    private bool BottomNavigation = true;

    protected override async Task OnInitializedAsync()
    {
        var settings = await _settings.GetSettingsAsync();
        DarkTheme = settings.Theme == AppTheme.Light ? false : true;
        BottomNavigation = settings.BottomNavigation;
    }

    private async Task OnNavigationChanged(bool value)
    {
        BottomNavigation = value;
        var settings = await _settings.GetSettingsAsync();
        await _settings.WriteSettingsAsync(settings with { BottomNavigation = value });
        _state.CallUpdate();
    }

    private async Task OnThemeChanged(bool value)
    {
        DarkTheme = value;
        var settings = await _settings.GetSettingsAsync();
        await _settings.WriteSettingsAsync(settings with { Theme = DarkTheme ? AppTheme.Dark : AppTheme.Light });
        _state.CallUpdate();
    }
}