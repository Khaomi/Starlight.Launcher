@using System.Globalization
@using AppTheme = Starlight.Launcher.Models.Settings.AppTheme;
@using Starlight.Launcher.Components.Atoms.Settings
@using Starlight.Launcher.Models.Data

@page "/settings"

<div class="app-bg"></div>

<div class="settings-page">
    <div class="settings-reset-button">
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.SettingsBackupRestore"
                   OnClick="OnResetSettings">
            @_localization["settings-menu-reset-option"]
        </MudButton>
    </div>

    <MudTabs @ref="_tabs" Elevation="0" ApplyEffectsToContainer="false" Class="settings-tabs pa-6" TabPanelsClass="settings-tabs-panels" ActivePanelIndexChanged="OnActivePanelIndexChanged">
        <MudTabPanel @ref="_settingsTab" Text="@_localization["settings-menu-general-category"]">
            <MudContainer MaxWidth="MaxWidth.Small" Class="pa-0">
                <MudText Typo="Typo.overline" Class="mud-text-secondary">@_localization["settings-menu-general-category"]</MudText>
                <SelectorListOption Title="@_localization["settings-menu-language-option"]" Description="@_localization["settings-menu-language-option-description"]" EmptyOption="true" EmptyOptionName="@_localization["settings-menu-language-option-system"]" Icon="@Icons.Material.Filled.Language" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings<string?>(s => s.SelectedLanguage)" SelfValueControlAction="x => OnLanguageChanged(x, null, (s, v) => s with { SelectedLanguage = v })" Values="_availableLanguages" DisplayTextSelector="@(x => new CultureInfo(x).EnglishName)" />
                <BoolOption Title="@_localization["settings-menu-multiple-clients-option"]" Description="@_localization["settings-menu-multiple-clients-option-description"]" Icon="@Icons.Material.Filled.MultipleStop" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.PreventMultipleClients)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { PreventMultipleClients = v })" />
                <FilePathOption Title="@_localization["settings-menu-data-folder-option"]" Description="@_localization["settings-menu-data-folder-option-description"]" Icon="@Icons.Material.Filled.FolderOpen" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.DirLauncherData)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { DirLauncherData = v })" AllowManualInput="false" PickAction="() => _fileDialog.PickFolderAsync()" />
            </MudContainer>
        </MudTabPanel>
        <MudTabPanel Text="@_localization["settings-menu-servers-category"]">
             <MudContainer MaxWidth="MaxWidth.Small" Class="pa-0">
                <AlternativeListOption Title="@_localization["settings-menu-hub-list-option"]" Description="@_localization["settings-menu-hub-list-option-description"]" AddButtonTooltip="@_localization["settings-menu-hub-list-option-add-tooltip"]" EmptyValuesString="@_localization["settings-menu-hub-list-option-empty-values"]" TextFieldLabel="@_localization["settings-menu-hub-list-option-text-label"]" Icon="@Icons.Material.Filled.Hub" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings<List<(string Url, long Priority)>>(s => [.. s.Hubs.Select(h => (h.HubUri.ToString(), h.Priority))])" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { Hubs = ConvertToHubList(v) })" />
                <AlternativeSelectorListOption Title="@_localization["settings-menu-auth-list-option"]" Description="@_localization["settings-menu-auth-list-option-description"]" AddButtonTooltip="@_localization["settings-menu-auth-list-option-add-tooltip"]" EmptyValuesString="@_localization["settings-menu-auth-list-option-empty-values"]" TextFieldLabel="@_localization["settings-menu-auth-list-option-text-label"]" Icon="@Icons.Material.Filled.Key" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings<(List<string>, string?)>(s => (s.AuthServerUrls, s.SelectedAuthServer))" SelfValueControlAction="(a, b) => OnSettingChanged((a, b), null, (s, v) => s with { AuthServerUrls = v.a, SelectedAuthServer = v.b })" />
            </MudContainer>
        </MudTabPanel>
        <MudTabPanel Text="@_localization["settings-menu-appearance-category"]">
            <MudContainer MaxWidth="MaxWidth.Small" Class="pa-0">
                <MudText Typo="Typo.overline" Class="mud-text-secondary">@_localization["settings-menu-general-category"]</MudText>
                <EnumOption Title="@_localization["settings-menu-theme-option"]" Description="@_localization["settings-menu-theme-option-description"]" Icon="@Icons.Material.Filled.DarkMode" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => (int)s.Theme)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { Theme = (AppTheme)v }, true)" Values="new AppTheme()" />
                <EnumOption Title="@_localization["settings-menu-navigation-bar-option"]" Description="@_localization["settings-menu-navigation-bar-option-description"]" Icon="@Icons.Material.Filled.Menu" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => (int)s.Navigation)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { Navigation = (ElementPosition)v }, true)" Values="new ElementPosition()" />
                <BoolOption Title="@_localization["settings-menu-discord-presence-option"]" Description="@_localization["settings-menu-discord-presence-option-description"]" Icon="@Icons.Custom.Brands.Discord" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => !s.HidePresence)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { HidePresence = !v })" />
                <MudText Typo="Typo.overline" Class="mud-text-secondary">@_localization["settings-menu-server-list-category"]</MudText>
                <BoolOption Title="@_localization["settings-menu-bottom-search-option"]" Description="@_localization["settings-menu-bottom-search-option-description"]" Icon="@Icons.Material.Filled.Search" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.ServerListToolbarBottomSearch)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { ServerListToolbarBottomSearch = v })" />
                <EnumOption Title="@_localization["settings-menu-bottom-search-bar-option"]" Description="@_localization["settings-menu-bottom-search-bar-option-description"]" Icon="@Icons.Material.Filled.YoutubeSearchedFor" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => (int)s.ServerListToolBarSearchPosition)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { ServerListToolBarSearchPosition = (ElementPosition)v })" Values="new ElementPosition()" />
                <EnumOption Title="@_localization["settings-menu-bottom-tags-bar-option"]" Description="@_localization["settings-menu-bottom-tags-bar-option-description"]" Icon="@Icons.Material.Filled.VerticalAlignBottom" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => (int)s.ServerListToolBarBottomTagsPosition)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { ServerListToolBarBottomTagsPosition = (ElementPosition)v })" Values="new ElementPosition()" />
                <BoolOption Title="@_localization["settings-menu-tags-bar-open-option"]" Description="@_localization["settings-menu-tags-bar-open-option-description"]" Icon="@Icons.Material.Filled.OpenInBrowser" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.ServerListToolBarTagsBarOpen)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { ServerListToolBarTagsBarOpen = v })" />
                <MudText Typo="Typo.overline" Class="mud-text-secondary">@_localization["settings-menu-tray-category"]</MudText>
                <BoolOption Title="@_localization["settings-menu-tray-collapse-start-option"]" Description="@_localization["settings-menu-tray-collapse-start-option-description"]" Icon="@Icons.Material.Filled.PlayDisabled" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.CollapseInTrayOnStart)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { CollapseInTrayOnStart = v })" />
                <BoolOption Title="@_localization["settings-menu-tray-collapse-run-option"]" Description="@_localization["settings-menu-tray-collapse-run-option-description"]" Icon="@Icons.Material.Filled.VideogameAsset" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.CollapseInTrayAfterRun)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { CollapseInTrayAfterRun = v })" />
                <BoolOption Title="@_localization["settings-menu-tray-uncollapse-end-option"]" Description="@_localization["settings-menu-tray-uncollapse-end-option-description"]" Icon="@Icons.Material.Filled.VideogameAssetOff" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.UnCollapseFromTrayAfterEnd)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { UnCollapseFromTrayAfterEnd = v })" />
                <BoolOption Title="@_localization["settings-menu-tray-collapse-close-option"]" Description="@_localization["settings-menu-tray-collapse-close-option-description"]" Icon="@Icons.Material.Filled.Close" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.CollapseInTrayOnClose)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { CollapseInTrayOnClose = v })" />
                <BoolOption Title="@_localization["settings-menu-tray-collapse-minimize-option"]" Description="@_localization["settings-menu-tray-collapse-minimize-option-description"]" Icon="@Icons.Material.Filled.Minimize" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.CollapseInTrayOnMinimize)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { CollapseInTrayOnMinimize = v })" />
                <MudSpacer />
            </MudContainer>
        </MudTabPanel>
        <MudTabPanel Text="@_localization["settings-menu-development-category"]">
            <MudContainer MaxWidth="MaxWidth.Small" Class="pa-0">
                <MudText Typo="Typo.overline" Class="mud-text-secondary">@_localization["settings-menu-general-category"]</MudText>
                <BoolOption Title="@_localization["settings-menu-development-gles-option"]" Description="@_localization["settings-menu-development-gles-option-description"]" Icon="@Icons.Material.Filled.Accessibility" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.CompatMode)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { CompatMode = v })" />
                <BoolOption Title="@_localization["settings-menu-development-signing-option"]" Description="@_localization["settings-menu-development-signing-option-description"]" Icon="@Icons.Material.Filled.Signpost" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.DisableSigning)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { DisableSigning = v })" />
                <BoolOption Title="@_localization["settings-menu-development-engine-override-option"]" Description="@_localization["settings-menu-development-engine-override-option-description"]" Icon="@Icons.Material.Filled.Assignment" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.EngineOverrideEnabled)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { EngineOverrideEnabled = v })" />
                <FilePathOption Title="@_localization["settings-menu-development-engine-override-path-option"]" Description="@_localization["settings-menu-development-engine-override-path-option-description"]" Icon="@Icons.Material.Filled.Folder" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.EngineOverridePath)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { EngineOverridePath = v })" Helper="Write Path To Engine Executable" Label="Engine Path" HelperOnFocus="true" PickAction="@(() => _fileDialog.PickFileAsync("Engine archive\0*.zip\0All Files\0*.*\0\0"))" />
                <TimeSpanOption Title="@_localization["settings-menu-development-robust-manifest-cache-time-option"]" Description="@_localization["settings-menu-development-robust-manifest-cache-time-option-description"]" Icon="@Icons.Material.Filled.Timer" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.RobustManifestCacheTime)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { RobustManifestCacheTime = v })" />
                <NumericFieldOption Title="@_localization["settings-menu-development-max-versions-option"]" Description="@_localization["settings-menu-development-max-versions-option-description"]" Icon="@Icons.Material.Filled.Numbers" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.MaxVersionsToKeep)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { MaxVersionsToKeep = v })" />
                <NumericFieldOption Title="@_localization["settings-menu-development-max-fork-versions-option"]" Description="@_localization["settings-menu-development-max-fork-versions-option-description"]" Icon="@Icons.Material.Filled.Numbers" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.MaxForkVersionsToKeep)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { MaxForkVersionsToKeep = v })" />
            </MudContainer>
        </MudTabPanel>
    </MudTabs>
</div>
