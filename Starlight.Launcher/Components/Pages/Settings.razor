@using AppTheme = Starlight.Launcher.Models.Settings.AppTheme;
@using Starlight.Launcher.Components.Atoms.Settings
@using Starlight.Launcher.Models.Data

@page "/settings"

<div class="settings-page">
    <MudTabs @ref="tabs" Elevation="0" ApplyEffectsToContainer="false" Class="settings-tabs pa-6" TabPanelsClass="settings-tabs-panels" ActivePanelIndexChanged="OnActivePanelIndexChanged">
        <MudTabPanel @ref="settingsTab" Text="@Localization["settings-menu-general-category"]">
            <MudContainer MaxWidth="MaxWidth.Small" Class="pa-0">
                <MudText Typo="Typo.overline" Class="mud-text-secondary">@Localization["settings-menu-general-category"]</MudText>
                <SelectorListOption Title="@Localization["settings-menu-language-option"]" Description="@Localization["settings-menu-language-option-description"]" EmptyOption="true" EmptyOptionName="@Localization["settings-menu-language-option-system"]" Icon="@Icons.Material.Filled.Language" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings<string?>(s => s.SelectedLanguage)" SelfValueControlAction="x => OnLanguageChanged(x, null, (s, v) => s with { SelectedLanguage = v })" Values="AvailableLanguages" />
                <AlternativeListOption Title="@Localization["settings-menu-hub-list-option"]" Description="@Localization["settings-menu-hub-list-option-description"]" AddButtonTooltip="@Localization["settings-menu-hub-list-option-add-tooltip"]" EmptyValuesString="@Localization["settings-menu-hub-list-option-empty-values"]" TextFieldLabel="@Localization["settings-menu-hub-list-option-text-label"]" Icon="@Icons.Material.Filled.Hub" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings<List<(string Url, long Priority)>>(s => [.. s.Hubs.Select(h => (h.HubUri.ToString(), h.Priority))])" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { Hubs = ConvertToHubList(v) })" />
            </MudContainer>
        </MudTabPanel>
        <MudTabPanel Text="@Localization["settings-menu-appearance-category"]">
            <MudContainer MaxWidth="MaxWidth.Small" Class="pa-0">
                <MudText Typo="Typo.overline" Class="mud-text-secondary">@Localization["settings-menu-general-category"]</MudText>
                <EnumOption Title="@Localization["settings-menu-theme-option"]" Description="@Localization["settings-menu-theme-option-description"]" Icon="@Icons.Material.Filled.DarkMode" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => (int)s.Theme)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { Theme = (AppTheme)v }, true)" Values="new AppTheme()" />
                <EnumOption Title="@Localization["settings-menu-navigation-bar-option"]" Description="@Localization["settings-menu-navigation-bar-option-description"]" Icon="@Icons.Material.Filled.Menu" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => (int)s.Navigation)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { Navigation = (ElementPosition)v }, true)" Values="new ElementPosition()" />
                <BoolOption Title="@Localization["settings-menu-discord-presence-option"]" Description="@Localization["settings-menu-discord-presence-option-description"]" Icon="@Icons.Custom.Brands.Discord" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => !s.HidePresence)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { HidePresence = !v })" />
                <MudText Typo="Typo.overline" Class="mud-text-secondary">@Localization["settings-menu-server-list-category"]</MudText>
                <BoolOption Title="@Localization["settings-menu-bottom-search-option"]" Description="@Localization["settings-menu-bottom-search-option-description"]" Icon="@Icons.Material.Filled.Search" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.ServerListToolbarBottomSearch)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { ServerListToolbarBottomSearch = v })" />
                <EnumOption Title="@Localization["settings-menu-bottom-search-bar-option"]" Description="@Localization["settings-menu-bottom-search-bar-option-description"]" Icon="@Icons.Material.Filled.YoutubeSearchedFor" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => (int)s.ServerListToolBarSearchPosition)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { ServerListToolBarSearchPosition = (ElementPosition)v })" Values="new ElementPosition()" />
                <EnumOption Title="@Localization["settings-menu-bottom-tags-bar-option"]" Description="@Localization["settings-menu-bottom-tags-bar-option-description"]" Icon="@Icons.Material.Filled.VerticalAlignBottom" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => (int)s.ServerListToolBarBottomTagsPosition)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { ServerListToolBarBottomTagsPosition = (ElementPosition)v })" Values="new ElementPosition()" />
                <BoolOption Title="@Localization["settings-menu-tags-bar-open-option"]" Description="@Localization["settings-menu-tags-bar-open-option-description"]" Icon="@Icons.Material.Filled.OpenInBrowser" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.ServerListToolBarTagsBarOpen)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { ServerListToolBarTagsBarOpen = v })" />
                <MudText Typo="Typo.overline" Class="mud-text-secondary">@Localization["settings-menu-tray-category"]</MudText>
                <BoolOption Title="@Localization["settings-menu-tray-collapse-start-option"]" Description="@Localization["settings-menu-tray-collapse-start-option-description"]" Icon="@Icons.Material.Filled.PlayDisabled" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.CollapseInTrayOnStart)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { CollapseInTrayOnStart = v })" />
                <BoolOption Title="@Localization["settings-menu-tray-collapse-run-option"]" Description="@Localization["settings-menu-tray-collapse-run-option-description"]" Icon="@Icons.Material.Filled.VideogameAsset" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.CollapseInTrayAfterRun)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { CollapseInTrayAfterRun = v })" />
                <BoolOption Title="@Localization["settings-menu-tray-collapse-close-option"]" Description="@Localization["settings-menu-tray-collapse-close-option-description"]" Icon="@Icons.Material.Filled.Close" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.CollapseInTrayOnClose)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { CollapseInTrayOnClose = v })" />
                <BoolOption Title="@Localization["settings-menu-tray-collapse-minimize-option"]" Description="@Localization["settings-menu-tray-collapse-minimize-option-description"]" Icon="@Icons.Material.Filled.Minimize" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.CollapseInTrayOnMinimize)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { CollapseInTrayOnMinimize = v })" />
                <MudSpacer />
            </MudContainer>
        </MudTabPanel>
        <MudTabPanel Text="@Localization["settings-menu-development-category"]">
            <MudContainer MaxWidth="MaxWidth.Small" Class="pa-0">
                <MudText Typo="Typo.overline" Class="mud-text-secondary">@Localization["settings-menu-general-category"]</MudText>
                <BoolOption Title="@Localization["settings-menu-development-gles-option"]" Description="@Localization["settings-menu-development-gles-option-description"]" Icon="@Icons.Material.Filled.Accessibility" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.CompatMode)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { CompatMode = v })" />
                <BoolOption Title="@Localization["settings-menu-development-signing-option"]" Description="@Localization["settings-menu-development-signing-option-description"]" Icon="@Icons.Material.Filled.Signpost" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.DisableSigning)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { DisableSigning = v })" />
                <BoolOption Title="@Localization["settings-menu-development-engine-override-option"]" Description="@Localization["settings-menu-development-engine-override-option-description"]" Icon="@Icons.Material.Filled.Assignment" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.EngineOverrideEnabled)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { EngineOverrideEnabled = v })" />
                <FieldOption Title="@Localization["settings-menu-development-engine-override-path-option"]" Description="@Localization["settings-menu-development-engine-override-path-option-description"]" Icon="@Icons.Material.Filled.Folder" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.EngineOverridePath)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { EngineOverridePath = v })" Helper="Write Path To Engine Executable" Label="Engine Path" HelperOnFocus="true" />
                <TimeSpanOption Title="@Localization["settings-menu-development-robust-manifest-cache-time-option"]" Description="@Localization["settings-menu-development-robust-manifest-cache-time-option-description"]" Icon="@Icons.Material.Filled.Timer" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.RobustManifestCacheTime)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { RobustManifestCacheTime = v })" />
                <NumericFieldOption Title="@Localization["settings-menu-development-max-versions-option"]" Description="@Localization["settings-menu-development-max-versions-option-description"]" Icon="@Icons.Material.Filled.Numbers" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.MaxVersionsToKeep)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { MaxVersionsToKeep = v })" />
                <NumericFieldOption Title="@Localization["settings-menu-development-max-fork-versions-option"]" Description="@Localization["settings-menu-development-max-fork-versions-option-description"]" Icon="@Icons.Material.Filled.Numbers" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.MaxForkVersionsToKeep)" SelfValueControlAction="x => OnSettingChanged(x, null, (s, v) => s with { MaxForkVersionsToKeep = v })" />
            </MudContainer>
        </MudTabPanel>
    </MudTabs>
</div>