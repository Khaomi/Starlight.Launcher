@using AppTheme = Starlight.Launcher.Models.Settings.AppTheme;
@using Starlight.Launcher.Models.Data

@page "/settings"

<MudTabs Elevation="0" ApplyEffectsToContainer="true" Class="settings-tabs pa-6">
    <MudTabPanel Text="@Localization["settings-menu-general-category"]">
        <MudContainer MaxWidth="MaxWidth.Small" Class="pa-0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary">@Localization["settings-menu-general-category"]</MudText>
            <SettingsSelectorListOption Title="@Localization["settings-menu-language-option"]" Description="@Localization["settings-menu-language-option-description"]" EmptyOption="true" EmptyOptionName="@Localization["settings-menu-language-option-system"]" Icon="@Icons.Material.Filled.Language" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings<string?>(s => s.SelectedLanguage)" SelfValueControlAction="x => OnLanguageChanged(x, null, (s, v) => s with { SelectedLanguage = v })" Values="AvailableLanguages" />
            <SettingsAlternativeListOption Title="@Localization["settings-menu-hub-list-option"]" Description="@Localization["settings-menu-hub-list-option-description"]" AddButtonTooltip="@Localization["settings-menu-hub-list-option-add-tooltip"]" EmptyValuesString="@Localization["settings-menu-hub-list-option-empty-values"]" TextFieldLabel="@Localization["settings-menu-hub-list-option-text-label"]" Icon="@Icons.Material.Filled.Hub" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings<List<(string Url, long Priority)>>(s => [.. s.Hubs.Select(h => (h.HubUri.ToString(), h.Priority))])" SelfValueControlAction="x => OnListSettingChanged(x, null, (s, v) => s with { Hubs = ConvertToHubList(v) })" />
        </MudContainer>
    </MudTabPanel>
    <MudTabPanel Text="@Localization["settings-menu-appearance-category"]">
        <MudContainer MaxWidth="MaxWidth.Small" Class="pa-0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary">@Localization["settings-menu-general-category"]</MudText>
            <SettingsEnumOption Title="@Localization["settings-menu-theme-option"]" Description="@Localization["settings-menu-theme-option-description"]" Icon="@Icons.Material.Filled.DarkMode" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => (int)s.Theme)" SelfValueControlAction="x => OnEnumSettingChanged(x, null, (s, v) => s with { Theme = (AppTheme)v })" Values="new AppTheme()" />
            <SettingsEnumOption Title="@Localization["settings-menu-navigation-bar-option"]" Description="@Localization["settings-menu-navigation-bar-option-description"]" Icon="@Icons.Material.Filled.Menu" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => (int)s.Navigation)" SelfValueControlAction="x => OnEnumSettingChanged(x, null, (s, v) => s with { Navigation = (ElementPosition)v })" Values="new ElementPosition()" />
            <MudText Typo="Typo.overline" Class="mud-text-secondary">@Localization["settings-menu-server-list-category"]</MudText>
            <SettingsBoolOption Title="@Localization["settings-menu-bottom-search-option"]" Description="@Localization["settings-menu-bottom-search-option-description"]" Icon="@Icons.Material.Filled.Search" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.ServerListToolbarBottomSearch)" SelfValueControlAction="x => OnBoolSettingChanged(x, null, (s, v) => s with { ServerListToolbarBottomSearch = v })" />
            <SettingsEnumOption Title="@Localization["settings-menu-bottom-search-bar-option"]" Description="@Localization["settings-menu-bottom-search-bar-option-description"]" Icon="@Icons.Material.Filled.YoutubeSearchedFor" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => (int)s.ServerListToolBarSearchPosition)" SelfValueControlAction="x => OnEnumSettingChanged(x, null, (s, v) => s with { ServerListToolBarSearchPosition = (ElementPosition)v })" Values="new ElementPosition()" />
            <SettingsEnumOption Title="@Localization["settings-menu-bottom-tags-bar-option"]" Description="@Localization["settings-menu-bottom-tags-bar-option-description"]" Icon="@Icons.Material.Filled.VerticalAlignBottom" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => (int)s.ServerListToolBarBottomTagsPosition)" SelfValueControlAction="x => OnEnumSettingChanged(x, null, (s, v) => s with { ServerListToolBarBottomTagsPosition = (ElementPosition)v })" Values="new ElementPosition()" />
            <SettingsBoolOption Title="@Localization["settings-menu-tags-bar-open-option"]" Description="@Localization["settings-menu-tags-bar-open-option-description"]" Icon="@Icons.Material.Filled.OpenInBrowser" SelfValueControl="true" SelfValueControlInitialization="async () => await FetchSettings(s => s.ServerListToolBarTagsBarOpen)" SelfValueControlAction="x => OnBoolSettingChanged(x, null, (s, v) => s with { ServerListToolBarTagsBarOpen = v })" />
        </MudContainer>
    </MudTabPanel>
</MudTabs>