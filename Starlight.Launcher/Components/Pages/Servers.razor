@page "/servers"
@using Starlight.Launcher.Services.ServerStatus
@implements IDisposable
@inject HubServerFetcher Fetcher

<div class="server-page">
    @if (Fetcher.Status == RefreshListStatus.NotUpdated || Fetcher.Status == RefreshListStatus.UpdatingMaster)
    {
        <div class="server-page__state">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Medium" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">Loading servers…</MudText>
        </div>
    }
    else if (Fetcher.Status == RefreshListStatus.Error && _totalCount == 0)
    {
        <div class="server-page__state">
            <MudIcon Icon="@Icons.Material.Filled.CloudOff" Size="Size.Large" Color="Color.Error" />
            <MudText Typo="Typo.subtitle1">Failed to fetch server list</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="HandleRefresh">
                Try again
            </MudButton>
        </div>
    }
    else if (_filteredServers.Count == 0)
    {
        <div class="server-page__state">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Default" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @(_totalCount == 0 ? "No servers online right now." : "No servers match your filters.")
            </MudText>
            @if (_totalCount > 0)
            {
                <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="ClearFilters">
                    Clear filters
                </MudButton>
            }
        </div>
    }
    else
    {
        <MudPaper Elevation="0" Square="true" Class="server-toolbar">
            <ServerListSearchBar Filters="_filters" Status="Fetcher.Status" TotalCount="_totalCount" FilteredCount="_filteredServers.Count" OnRefresh="HandleRefresh" />
            <ServerListTagsBar Filters="_filters" AvailableRPTags="_availableRPTags" AvailableLangTags="_availableLangTags" AvailableRegionTags="_availableRegionTags" />
        </MudPaper>
        @if (Fetcher.Status == RefreshListStatus.PartialError)
        {
            <MudAlert Severity="Severity.Warning" Square="true" Dense="true"
                      ShowCloseIcon="false" Class="server-page__alert">
                Some hubs could not be reached. The list may be incomplete.
            </MudAlert>
        }
        <div class="server-page__list">
            <MudVirtualize Items="_filteredServers"
                        Context="server"
                        ItemSize="56"
                        OverscanCount="3">
                <ServerListItem @key="server.Address" Data="server"
                                OnClick="HandleServerClick"
                                OnInfoNeeded="HandleInfoNeeded" />
            </MudVirtualize>
        </div>
    }
</div>