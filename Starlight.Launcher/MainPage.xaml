<ContentPage xmlns:local="clr-namespace:Starlight.Launcher"
             xmlns:components="clr-namespace:Starlight.Launcher.Components"
             x:Class="Starlight.Launcher.MainPage">

    <BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
        <BlazorWebView.RootComponents>
            <RootComponent Selector="#app" ComponentType="{x:Type components:Routes}" />
        </BlazorWebView.RootComponents>
    </BlazorWebView>

</ContentPage>
